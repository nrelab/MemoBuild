# MemoBuild Production Environment Variables
# Copy this file to .env and customize for your environment

# Cluster Configuration
MEMOBUILD_NODE_ID=node1
MEMOBUILD_CLUSTER_PEERS=http://memobuild-node2:8080,http://memobuild-node3:8080

# Database Configuration
MEMOBUILD_DATABASE_URL=postgresql://memobuild:password@localhost:5432/memobuild

# Redis Configuration
MEMOBUILD_REDIS_URL=redis://localhost:6379

# Object Storage Configuration
MEMOBUILD_STORAGE_BACKEND=s3
MEMOBUILD_STORAGE_BUCKET=memobuild-cache
MEMOBUILD_STORAGE_ENDPOINT=http://localhost:9000
MEMOBUILD_STORAGE_ACCESS_KEY=minioadmin
MEMOBUILD_STORAGE_SECRET_KEY=minioadmin

# Logging Configuration
MEMOBUILD_LOG_LEVEL=info

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Security Configuration (for future phases)
# MEMOBUILD_TLS_CERT=/path/to/cert.pem
# MEMOBUILD_TLS_KEY=/path/to/key.pem
# MEMOBUILD_TLS_CA=/path/to/ca.pem
# MEMOBUILD_ADMIN_TOKEN=admin-token-here

# Cache Configuration
MEMOBUILD_CACHE_DIR=/tmp/memobuild-cache
MEMOBUILD_REDIS_CACHE_TTL=3600

# Performance Tuning
MEMOBUILD_MAX_CONCURRENT_BUILDS=10
MEMOBUILD_BUILD_TIMEOUT=1800
